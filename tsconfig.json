{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "jsx": "react-jsx",
    "declaration": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@server/*": ["./server/src/*"],
      "@web/*": ["./web/src/*"]
    }
  },
  "include": ["server/src/**/*", "web/src/**/*", "prisma/**/*"],
  "exclude": ["node_modules", "dist"]
}
