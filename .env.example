# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hoabot

# Auth
JWT_SECRET=replace-with-random-64-char-hex-string

# Server
PORT=4100
CORS_ORIGIN=https://your-domain.com

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLATFORM_FEE_PERCENT=2.5
STRIPE_PRICE_ID=price_...

# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# Email (Resend)
RESEND_API_KEY=re_...

# Google Maps (exposed to frontend via VITE_ prefix — restrict by HTTP referrer in Google Cloud Console)
VITE_GOOGLE_MAPS_API_KEY=AIza...

# Xero (optional)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# Token encryption (optional — 32-byte hex key for encrypting OAuth tokens at rest)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# LinkedIn (optional — for content pipeline only)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:4100/api/linkedin/callback

# Twitter/X (optional — for content pipeline only)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
